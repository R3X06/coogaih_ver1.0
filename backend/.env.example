# Supabase/Postgres connection string, asyncpg driver
# e.g. postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/coogaih

# comma-separated origins allowed to call the API (extension id, dashboard dev server, etc.)
CORS_ORIGINS=http://localhost:5173

ENV=development
